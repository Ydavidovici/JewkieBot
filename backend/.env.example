# Backend environment — copy to `.env` and fill in.

# --- Lichess ---
# Personal API token with `bot:play` scope. Required to start the Lichess bot.
# Lowercase name matches the existing code (process.env.lichess_api_token).
lichess_api_token=

# Max simultaneous games the bot will accept.
LICHESS_MAX_GAMES=4

# --- Engine spawn cap ---
# Hard ceiling on UciEngine processes managed by EngineManager.
# Independent of LICHESS_MAX_GAMES — catches bugs in any caller. When at the
# cap, new spawns are refused; existing engines are NOT killed.
# Defaults to LICHESS_MAX_GAMES + 3 if unset.
ENGINE_HARD_CAP=7

# --- HTTP server ---
PORT=8000

# --- Discord (optional) ---
# Both DISCORD_BOT_TOKEN and DISCORD_CHANNEL_ID must be set to enable Discord.
# Leave both blank to disable; the rest of the system runs unchanged.
#
# Token: from https://discord.com/developers/applications -> your app -> Bot -> Reset Token
# Channel ID: in Discord with Developer Mode on, right-click channel -> Copy ID
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# URL the Discord bot pings for uptime monitoring. Defaults to the local
# /api/health if unset. Override if the bot runs separately from the backend.
HEALTH_URL=http://localhost:8000/api/health

# --- Remote Engine (SSH) ---
# Set to true to execute engines remotely via SSH.
REMOTE_ENGINE_ENABLED=false
REMOTE_SSH_USER=myuser
REMOTE_SSH_HOST=192.168.1.100
REMOTE_SSH_KEY_PATH=/home/myuser/.ssh/id_rsa
REMOTE_STOCKFISH_PATH=/opt/stockfish/stockfish