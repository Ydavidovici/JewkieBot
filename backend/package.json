{
    "name": "backend",
    "version": "2.1.0",
    "type": "module",
    "private": true,
    "scripts": {
        "start": "bun run src/server.js",
        "dev": "bun --hot src/server.js",
        "build:engine": "bun run src/scripts/buildEngine.js",
        "test": "bun test",
        "tourney": "bun run src/scripts/runTourney.js",
        "setup": "bun run src/scripts/setup_cutie.js",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "bun run src/scripts/migrate.js",
        "download:book": "bun run src/scripts/downloadBook.js",
        "download:book:gm2001": "bun run src/scripts/downloadBook.js https://github.com/gmcheems-org/free-opening-books/raw/main/books/bin/gm2001.bin",
        "download:book:titans": "bun run src/scripts/downloadBook.js https://github.com/gmcheems-org/free-opening-books/raw/main/books/bin/Titans.bin",
        "download:book:human": "bun run src/scripts/downloadBook.js https://github.com/gmcheems-org/free-opening-books/raw/main/books/bin/Human.bin",
        "download:book:cerebellum": "bun run src/scripts/downloadCerebellum.js"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "drizzle-kit": "^0.31.7"
    },
    "dependencies": {
        "cors": "^2.8.6",
        "discord.js": "^14.26.4",
        "drizzle-orm": "^0.44.7",
        "express": "^5.1.0",
        "postgres": "^3.4.9"
    }
}