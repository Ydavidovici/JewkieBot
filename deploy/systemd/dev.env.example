# Development env for chess-engine-dev.service.
# Copy to /etc/chess-engine/dev.env and edit. Uses a separate port + Discord app
# so dev traffic and alerts never mix with production.

# Absolute path to your locally built engine binary.
ENGINE_PATH=/home/youruser/Chess-Engine/engines/jewkiebot/build/jewkiebot

PORT=8001
LICHESS_MAX_GAMES=2
ENGINE_HARD_CAP=5

lichess_api_token=

# Separate Discord app for dev.
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
HEALTH_URL=http://localhost:8001/api/health
