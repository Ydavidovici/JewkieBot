# Production env for chess-engine.service.
# Copy to /etc/chess-engine/prod.env and lock it down: chown root:chess, chmod 0640.
# systemd EnvironmentFile format: KEY=value, one per line, no `export`, no surrounding quotes.

# Absolute path to the production engine binary (overrides server.js auto-detection).
ENGINE_PATH=/opt/chess-engine/backend/src/jewkiebot

PORT=8000
LICHESS_MAX_GAMES=4
ENGINE_HARD_CAP=7

# Lichess token with bot:play scope (lowercase name matches the code).
lichess_api_token=

# Production Discord app — both must be set to enable Discord.
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
HEALTH_URL=http://localhost:8000/api/health
